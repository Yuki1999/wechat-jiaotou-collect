# ============================================================================
# wechat2rss 私有部署 — 环境变量
# 复制此文件为 .env 后填写。.env 不要提交到 Git。
# ============================================================================

# ---- 必填三项（来源：wechat2rss.xlab.app 购买后官方邮件） ----
LIC_EMAIL=your-order-email@example.com
LIC_CODE=00000000-0000-0000-0000-000000000000

# ---- 服务对外可访问地址（含端口）——必填 ----
# 这是 RSS feed 内 link 字段会拼出的前缀，不是监听端口
# 内网示例：  192.168.11.22:8080
# 公网示例：  rss.example.gov.cn         (此时建议 RSS_HTTPS=1)
RSS_HOST=192.168.11.22:8080
RSS_HTTPS=0

# ---- 服务密码（保护写/读 API）；强烈建议设置随机值 ----
# 部署后调用 /list /opml /add /del 等接口都需要 ?k=<此值>
RSS_TOKEN=please-change-me-to-a-long-random-string

# ---- 监听端口（宿主机 → 容器） ----
HOST_PORT=8080

# ---- 其它可选项（保留默认即可，按需调整） ----
RSS_MAX_ITEM_COUNT=50
RSS_KEEP_OLD_COUNT=-1
RSS_ENC_FEED_ID=0
RSS_PROXY_DISABLE_IMG=0

# ---- 镜像（Docker Hub 不稳可切换到官方备用） ----
# WECHAT2RSS_IMAGE=docker.xlab.app/ttttmr/wechat2rss:latest
WECHAT2RSS_IMAGE=ttttmr/wechat2rss:latest

# ============================================================================
# 与 党政办信息系统（本项目）对接相关
# ============================================================================
# 本项目（demo）默认监听 http://127.0.0.1:8080，与 wechat2rss 默认端口冲突！
# 上面 HOST_PORT 建议改为 8090（避开冲突），并相应调整 RSS_HOST：
#   HOST_PORT=8090
#   RSS_HOST=192.168.11.22:8090
DZB_BASE=http://127.0.0.1:8080      # 党政办信息系统对外地址
DZB_TOKEN=                           # 如启用了简单鉴权再填；当前 demo 未启用
